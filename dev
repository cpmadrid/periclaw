#!/usr/bin/env bash

# Mission Control Desktop — Developer Convenience Script
# Thin router; activity implementations live in Scripts/.
# Mirrors the pattern used by apps across Sassy Dog (lupita, velovate,
# tailoredtip, quickshot, brewslate).
#
# Usage: ./dev <activity> [options]

set -euo pipefail

DEV_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./Scripts/lib.sh
source "${DEV_SCRIPT_DIR}/Scripts/lib.sh"

show_help() {
    cat << 'EOF'
Mission Control Desktop — Developer Convenience Script

USAGE:
    ./dev <activity> [options]

ACTIVITIES:
    run (r)                  Build and run the app (default mode: auto)
    build (b)                Build a binary
    test (t)                 Run cargo tests
    check (c)                cargo check --all-targets (fast, no codegen)
    lint (l)                 cargo clippy --all-targets -- -D warnings
    fmt (f)                  cargo fmt (add --check for dry-run)
    ci                       Full CI pipeline (fmt-check, clippy, test, release build)
    cross-arm64              Cross-compile for ubu-3xdv (aarch64-linux-gnu)
    clean                    cargo clean
    version (v)              Print app version, build number, git sha
    help (h, -h, --help)     Show this help

RUN OPTIONS:
    --mode <mock|ws|auto>    Data source. Default: auto (use env vars as-is)
                               mock — scripted fixture (no network)
                               ws   — native WS push stream (default)
    --release, -r            Release build
    --no-build               Skip cargo build; exec the pre-built binary

LOGGING (run):
    --log <console|file|both>
                             Where logs go. Default: console.
                               console — stderr/stdout (default dev)
                               file    — redirect to a timestamped file
                               both    — tee to both
    --log-level <level>      trace | debug | info (default) | warn | error
    --log-file <path>        Override default log path
                             (default: Logs/desktop-<timestamp>.log)

BUILD OPTIONS:
    --release, -r            Release build + strip
    --clean                  cargo clean first

FMT OPTIONS:
    --check                  cargo fmt --all --check (doesn't modify)

GENERAL:
    --verbose                Verbose logging (RUST_LOG=sassy_mc=trace)
    --quiet                  Minimal logging (RUST_LOG=warn)

EXAMPLES:
    ./dev run                               # auto mode, debug, console logs
    ./dev run --mode mock                   # scripted fixture
    ./dev run --log both                    # tee logs to console + file
    ./dev run --log file --log-level trace  # capture verbose trace to file
    ./dev run --log-file /tmp/ws.log --log both
    ./dev run --release                     # release build + run
    ./dev build --release                   # stripped release binary
    ./dev test                              # cargo test
    ./dev ci                                # everything CI runs
    ./dev cross-arm64                       # build for ubu-3xdv
    ./dev fmt --check                       # format check without writing

EOF
}

# Defaults
ACTIVITY=""
BUILD_TYPE="debug"
MODE="auto"
NO_BUILD=false
CLEAN=false
FMT_CHECK=false
VERBOSE=false
QUIET=false
LOG_TARGETS="console"         # console | file | both
LOG_LEVEL="info"              # trace | debug | info | warn | error
LOG_FILE=""                   # empty → default to Logs/desktop-<timestamp>.log

# -----------------------------------------------------------------------------
# Arg parsing — activity first, then flags.
# -----------------------------------------------------------------------------

if [[ $# -eq 0 ]]; then
    show_help
    exit 0
fi

ACTIVITY="$1"
shift

while [[ $# -gt 0 ]]; do
    case "$1" in
        --release|-r)     BUILD_TYPE="release"; shift ;;
        --debug|-d)       BUILD_TYPE="debug"; shift ;;
        --mode)           MODE="$2"; shift 2 ;;
        --no-build)       NO_BUILD=true; shift ;;
        --clean)          CLEAN=true; shift ;;
        --check)          FMT_CHECK=true; shift ;;
        --verbose)        VERBOSE=true; shift ;;
        --quiet)          QUIET=true; shift ;;
        --log)            LOG_TARGETS="$2"; shift 2 ;;
        --log-level)      LOG_LEVEL="$2"; shift 2 ;;
        --log-file)       LOG_FILE="$2"; shift 2 ;;
        -h|--help|help)   show_help; exit 0 ;;
        --)               shift; break ;;
        *)                # Pass unknown args through to subscripts (e.g., cargo test filter)
                          EXTRA_ARGS+=("$1"); shift ;;
    esac
done
EXTRA_ARGS=("${EXTRA_ARGS[@]:-}")

# Validate logging flags.
case "$LOG_TARGETS" in
    console|file|both) ;;
    *) print_error "invalid --log '$LOG_TARGETS' (expected: console, file, both)"; exit 1 ;;
esac
case "$LOG_LEVEL" in
    trace|debug|info|warn|error) ;;
    *) print_error "invalid --log-level '$LOG_LEVEL' (expected: trace, debug, info, warn, error)"; exit 1 ;;
esac

# `--verbose` / `--quiet` are legacy shortcuts that override --log-level.
if [[ "$VERBOSE" == "true" ]]; then
    LOG_LEVEL="trace"
elif [[ "$QUIET" == "true" ]]; then
    LOG_LEVEL="warn"
fi

# Build RUST_LOG from LOG_LEVEL. Our crate gets the requested level; all
# other crates stay at warn so we don't drown in iced/winit/wgpu chatter.
# Respect an existing RUST_LOG env var — it's a power-user override.
if [[ -z "${RUST_LOG:-}" ]]; then
    RUST_LOG="sassy_mc=${LOG_LEVEL},warn"
fi
export RUST_LOG

# Export knobs consumed by Scripts/*.sh
export BUILD_TYPE MODE NO_BUILD CLEAN LOG_TARGETS LOG_LEVEL LOG_FILE

# -----------------------------------------------------------------------------
# Activity dispatch
# -----------------------------------------------------------------------------

case "$ACTIVITY" in
    run|r)
        "${DEV_SCRIPT_DIR}/Scripts/run.sh"
        ;;
    build|b)
        "${DEV_SCRIPT_DIR}/Scripts/build.sh"
        ;;
    test|t)
        "${DEV_SCRIPT_DIR}/Scripts/test.sh" "${EXTRA_ARGS[@]}"
        ;;
    check|c)
        cd_to_project_root
        print_step "cargo check --all-targets"
        cargo check --all-targets
        print_success "check passed"
        ;;
    lint|l|clippy)
        cd_to_project_root
        print_step "cargo clippy --all-targets -- -D warnings"
        cargo clippy --all-targets -- -D warnings
        print_success "clippy clean"
        ;;
    fmt|f)
        cd_to_project_root
        if [[ "$FMT_CHECK" == "true" ]]; then
            print_step "cargo fmt --all -- --check"
            cargo fmt --all -- --check
            print_success "format clean"
        else
            print_step "cargo fmt --all"
            cargo fmt --all
            print_success "formatted"
        fi
        ;;
    ci)
        "${DEV_SCRIPT_DIR}/Scripts/ci.sh"
        ;;
    cross-arm64)
        "${DEV_SCRIPT_DIR}/Scripts/cross-arm64.sh"
        ;;
    clean)
        cd_to_project_root
        print_step "cargo clean"
        cargo clean
        print_success "cleaned"
        ;;
    version|v)
        cd_to_project_root
        print_info "$APP_NAME v${APP_VERSION} (#$(get_build_number), $(git_short_sha))"
        ;;
    help|h|-h|--help)
        show_help
        ;;
    *)
        print_error "unknown activity: ${ACTIVITY}"
        echo
        show_help
        exit 1
        ;;
esac
