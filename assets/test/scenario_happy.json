{
  "description": "Happy-path demo loop — crons cycle through idle → running → ok, one channel errors briefly, main stays idle. Used by OPENCLAW_MOCK=1.",
  "loop_seconds": 30,
  "ticks": [
    {
      "at_ms": 0,
      "crons": [
        { "name": "zpool-health-check",           "state": { "lastStatus": "ok",    "running": false } },
        { "name": "openclaw-auto-update",         "state": { "lastStatus": "ok",    "running": false } },
        { "name": "teamapp-velovate-sync-hourly", "state": { "lastStatus": "ok",    "running": false } },
        { "name": "velovate-weekly-digest",       "state": { "lastStatus": "ok",    "running": false } }
      ],
      "channels": [
        { "name": "slack",    "enabled": true, "connected": true },
        { "name": "telegram", "enabled": true, "connected": true },
        { "name": "whatsapp", "enabled": false, "connected": false }
      ],
      "main": { "id": "main", "model": "vllm/qwen3-14b", "state": "idle" }
    },
    {
      "at_ms": 4000,
      "crons": [
        { "name": "zpool-health-check",           "state": { "lastStatus": "ok",    "running": false } },
        { "name": "openclaw-auto-update",         "state": { "lastStatus": "ok",    "running": false } },
        { "name": "teamapp-velovate-sync-hourly", "state": { "lastStatus": "ok",    "running": true  } },
        { "name": "velovate-weekly-digest",       "state": { "lastStatus": "ok",    "running": false } }
      ],
      "channels": [
        { "name": "slack",    "enabled": true, "connected": true },
        { "name": "telegram", "enabled": true, "connected": true },
        { "name": "whatsapp", "enabled": false, "connected": false }
      ],
      "main": { "id": "main", "model": "vllm/qwen3-14b", "state": "running" }
    },
    {
      "at_ms": 10000,
      "crons": [
        { "name": "zpool-health-check",           "state": { "lastStatus": "ok",    "running": false } },
        { "name": "openclaw-auto-update",         "state": { "lastStatus": "error", "running": false, "lastError": "network timeout" } },
        { "name": "teamapp-velovate-sync-hourly", "state": { "lastStatus": "ok",    "running": false } },
        { "name": "velovate-weekly-digest",       "state": { "lastStatus": "ok",    "running": false } }
      ],
      "channels": [
        { "name": "slack",    "enabled": true, "connected": true },
        { "name": "telegram", "enabled": true, "connected": false, "lastError": "socket closed" },
        { "name": "whatsapp", "enabled": false, "connected": false }
      ],
      "main": { "id": "main", "model": "vllm/qwen3-14b", "state": "idle" }
    },
    {
      "at_ms": 18000,
      "crons": [
        { "name": "zpool-health-check",           "state": { "lastStatus": "ok",    "running": true  } },
        { "name": "openclaw-auto-update",         "state": { "lastStatus": "ok",    "running": false } },
        { "name": "teamapp-velovate-sync-hourly", "state": { "lastStatus": "ok",    "running": false } },
        { "name": "velovate-weekly-digest",       "state": { "lastStatus": "ok",    "running": true  } }
      ],
      "channels": [
        { "name": "slack",    "enabled": true, "connected": true },
        { "name": "telegram", "enabled": true, "connected": true },
        { "name": "whatsapp", "enabled": false, "connected": false }
      ],
      "main": { "id": "main", "model": "vllm/qwen3-14b", "state": "idle" }
    },
    {
      "at_ms": 25000,
      "crons": [
        { "name": "zpool-health-check",           "state": { "lastStatus": "ok",    "running": false } },
        { "name": "openclaw-auto-update",         "state": { "lastStatus": "ok",    "running": false } },
        { "name": "teamapp-velovate-sync-hourly", "state": { "lastStatus": "ok",    "running": false } },
        { "name": "velovate-weekly-digest",       "state": { "lastStatus": "ok",    "running": false } }
      ],
      "channels": [
        { "name": "slack",    "enabled": true, "connected": true },
        { "name": "telegram", "enabled": true, "connected": true },
        { "name": "whatsapp", "enabled": false, "connected": false }
      ],
      "main": { "id": "main", "model": "vllm/qwen3-14b", "state": "idle" }
    }
  ]
}
